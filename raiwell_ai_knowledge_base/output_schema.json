{
  "version": "0.1-demo",
  "output_format": "json_first_then_render_ui",
  "schema": {
    "wellness_summary": "string",
    "plan_type": "recovery_first | balanced_reset | active_reset | conservative_general_wellness",
    "risk_level": "low | medium | high",
    "food_journey": [{"meal_time": "string", "recommendation": "string", "why_it_fits": "string", "portion_note": "string", "safety_note": "string", "source_pattern_id": "string"}],
    "movement_plan": [{"activity_id": "string", "activity": "string", "duration_minutes": "number", "intensity": "string", "rpe": "string", "why_it_fits": "string", "downgrade_if": ["string"], "coach_review_required": "boolean"}],
    "peaceful_travel_route": [{"place_id": "string", "place_name": "string", "duration_minutes": "number", "crowd_level": "string", "why_it_fits": "string", "verification_status": "string"}],
    "local_experience_hidden_gem": [{"place_id": "string", "name": "string", "reason": "string", "community_impact": "string", "verification_status": "string"}],
    "local_wellness_network": [{"provider_id": "string", "provider_type": "string", "experience_name": "string", "pillar": "string", "verification_status": "string"}],
    "coach_notes": ["string"],
    "safety_considerations": ["string"],
    "community_impact": "string",
    "daily_nudges": ["string"],
    "missing_info_to_verify": ["string"]
  },
  "hard_rules": [
    "Only recommend places from chiangrai_places.json.",
    "If information is guessed or unknown, label it as estimated or needs verification.",
    "Do not invent partnerships.",
    "Do not make medical claims.",
    "Always include coach notes and safety considerations."
  ]
}
